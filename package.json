{
  "name": "my-screenshot-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4",
    "express": "^4.18.2",
    "puppeteer": "^21.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "screenshot": "node scripts/take-screenshot.js",
    "screenshot:ci": "npm run build && node scripts/take-screenshot.js",
    "screenshot:local": "npm run build && node scripts/take-screenshot.js",
    "create-dirs": "if not exist screenshots mkdir screenshots"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "express": "^5.2.1",
    "puppeteer": "^24.37.5",
    "serve-static": "^2.2.1"
  }
}
